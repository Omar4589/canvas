{
  "name": "doorline",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "start": "npm --prefix server start",
    "install:all": "npm --prefix server install && npm --prefix client install --include=dev",
    "heroku-postbuild": "npm run install:all && npm run build",
    "seed:admin": "npm --prefix server run seed:admin",
    "reconcile:counts": "npm --prefix server run reconcile:counts --"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
