{
  "expo": {
    "name": "Doorline",
    "slug": "canvass-mobile",
    "scheme": "canvass",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/AppIcons/appstore.png",
    "ios": {
      "bundleIdentifier": "com.canvassapp.mobile",
      "supportsTablet": false,
      "icon": "./assets/AppIcons/appstore.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Doorline needs your location to log when you knock on a door, so admins can verify field activity.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.canvassapp.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/AppIcons/adaptive-foreground.png",
        "monochromeImage": "./assets/AppIcons/adaptive-monochrome.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Doorline needs your location to log when you knock on a door."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/AppIcons/adaptive-foreground.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F9FAFB",
          "dark": {
            "image": "./assets/AppIcons/adaptive-foreground.png",
            "backgroundColor": "#0B0F19"
          }
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:4000",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4d913345-676f-4240-8f9a-6e8cafdda04c"
      }
    },
    "owner": "omar4589",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/4d913345-676f-4240-8f9a-6e8cafdda04c"
    }
  }
}
