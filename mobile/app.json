{
  "expo": {
    "name": "Doorline",
    "slug": "canvass-mobile",
    "scheme": "canvass",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/AppIcons/appstore.png",
    "ios": {
      "bundleIdentifier": "com.canvassapp.mobile",
      "supportsTablet": false,
      "icon": "./assets/AppIcons/appstore.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Doorline needs your location to log when you knock on a door, so admins can verify field activity.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.canvassapp.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/AppIcons/appstore.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Doorline needs your location to log when you knock on a door."
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "apiBaseUrl": "http://localhost:4000",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4d913345-676f-4240-8f9a-6e8cafdda04c"
      }
    },
    "owner": "omar4589",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4d913345-676f-4240-8f9a-6e8cafdda04c"
    }
  }
}
