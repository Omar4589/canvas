{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "REPLACE_WITH_YOUR_LAN_IP_OR_NGROK_URL"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.doorline.app"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.doorline.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "omar4589@hotmail.com",
        "appleTeamId": "62RUXR2CLQ"
      },
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
