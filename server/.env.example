PORT=4000
NODE_ENV=development

# Mongo
MONGODB_URI=mongodb://127.0.0.1:27017/canvass-app

# Auth
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=30d

# CORS
CLIENT_ORIGIN=http://localhost:5173

# Custom domains (production only). API_HOST locks that host to /api/* and
# redirects every other path to WEB_ORIGIN. Leave both unset in local dev.
# API_HOST=api.doorline.app
# WEB_ORIGIN=https://doorline.app

# Mapbox (public token starting with pk.* — used by the admin web map)
MAPBOX_PUBLIC_TOKEN=

# Redis (BullMQ job queue). Heroku Key-Value Store injects REDIS_URL as rediss://.
REDIS_URL=redis://127.0.0.1:6379
IMPORT_JOB_CONCURRENCY=2
TURF_JOB_CONCURRENCY=1

# First admin (used by seed:admin script)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=User
